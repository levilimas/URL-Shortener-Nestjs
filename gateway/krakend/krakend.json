{
    "version": 3,
    "name": "URL Shortener Gateway",
    "port": 8080,
    "cache_ttl": "3600s",
    "timeout": "3s",
    "extra_config": {
      "security/cors": {
        "allow_origins": ["*"],
        "allow_methods": ["GET", "POST", "PUT", "DELETE"],
        "allow_headers": ["Origin", "Authorization", "Content-Type"],
        "expose_headers": ["Content-Length"],
        "max_age": "12h"
      },
      "telemetry/logging": {
        "level": "INFO",
        "prefix": "[KRAKEND]",
        "stdout": true
      },
      "telemetry/metrics": {
        "collection_time": "60s",
        "proxy_disabled": false,
        "router_disabled": false,
        "backend_disabled": false,
        "endpoint_disabled": false,
        "listen_address": ":8090"
      }
    },
    "endpoints": [
      {
        "endpoint": "/api/auth/register",
        "method": "POST",
        "output_encoding": "json",
        "backend": [
          {
            "url_pattern": "/api/auth/register",
            "encoding": "json",
            "method": "POST",
            "host": ["http://api:3000"]
          }
        ]
      },
      {
        "endpoint": "/api/auth/login",
        "method": "POST",
        "output_encoding": "json",
        "backend": [
          {
            "url_pattern": "/api/auth/login",
            "encoding": "json",
            "method": "POST",
            "host": ["http://api:3000"]
          }
        ]
      },
      {
        "endpoint": "/api/urls",
        "method": "POST",
        "output_encoding": "json",
        "backend": [
          {
            "url_pattern": "/api/urls",
            "encoding": "json",
            "method": "POST",
            "host": ["http://api:3000"]
          }
        ]
      },
      {
        "endpoint": "/api/urls",
        "method": "GET",
        "output_encoding": "json",
        "input_headers": ["Authorization"],
        "backend": [
          {
            "url_pattern": "/api/urls",
            "encoding": "json",
            "method": "GET",
            "host": ["http://api:3000"]
          }
        ]
      },
      {
        "endpoint": "/api/shorten",
        "method": "POST",
        "output_encoding": "json",
        "backend": [
          {
            "url_pattern": "/api/shorten",
            "encoding": "json",
            "method": "POST",
            "host": ["http://api:3000"]
          }
        ]
      },
      {
        "endpoint": "/api/system/health",
        "method": "GET",
        "output_encoding": "json",
        "backend": [
          {
            "url_pattern": "/api/system/health",
            "encoding": "json",
            "method": "GET",
            "host": ["http://api:3000"]
          }
        ]
      }
    ]
  }