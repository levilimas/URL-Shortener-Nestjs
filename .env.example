# Application
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=url_shortener
# Opcional: sobrescreve DB_* para pg-boss e outras libs que aceitam URL única
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/url_shortener

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=1h

# URL prefix for shortened URLs (the base domain)
URL_PREFIX=http://localhost:3000

# Redis (cache de resolução shortCode → URL; opcional)
REDIS_ENABLED=false
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=

# PgBoss — fila assíncrona de analytics de clique (usa o mesmo Postgres)
# false = grava analytics no request path (síncrono)
PGBOSS_ENABLED=true
